# LabClaw Lab Manager — Production Environment
# Copy to .env and fill in ALL required values before docker compose up.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

# --- Domain (for Caddy auto-TLS) ---
DOMAIN=app.labclaw.org

# --- PostgreSQL ---
POSTGRES_USER=labmanager
POSTGRES_PASSWORD=           # REQUIRED: strong random password
POSTGRES_DB=labmanager
POSTGRES_RO_PASSWORD=        # REQUIRED: strong random password (for read-only RAG user)

# --- Application ---
ADMIN_SECRET_KEY=            # REQUIRED: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_ENABLED=true
SECURE_COOKIES=true          # Must be true when behind HTTPS

# --- Meilisearch ---
MEILI_ENV=production
MEILI_MASTER_KEY=            # REQUIRED in production: strong random key

# --- AI/VLM ---
GEMINI_API_KEY=              # REQUIRED for RAG + extraction
RAG_MODEL=gemini-2.5-flash   # Google GenAI API (NOT CLI): only gemini-2.5-flash/pro work
EXTRACTION_MODEL=gemini-3.1-flash-preview

# --- Optional ---
API_KEY=                     # For programmatic API access (X-Api-Key header)
OCR_MODEL=Qwen/Qwen3-VL-4B-Instruct
