{
    auto_https off
}

:80 {
    reverse_proxy app:8000 {
        header_up X-Forwarded-Proto https
    }
    encode gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob:; font-src 'self' https://fonts.gstatic.com; connect-src 'self'"
        Permissions-Policy "camera=(self), microphone=(), geolocation=()"
        -Server
    }

    log {
        output stdout
    }
}
