# Shen Lab Manager — Production Environment Configuration
# Copy to lab-manager/.env and replace all changeme_* values with real secrets.
# NEVER commit .env to git.
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ==============================================================================
# REQUIRED — must be set before docker compose up
# ==============================================================================

DOMAIN=shenlab.labclaw.org

# PostgreSQL
POSTGRES_USER=labmanager
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_DB=labmanager
POSTGRES_RO_PASSWORD=changeme_pg_ro_password

# Application
ADMIN_SECRET_KEY=changeme_session_key_64hex
ADMIN_PASSWORD=changeme_admin_password
MEILI_MASTER_KEY=changeme_meilisearch_key_64hex

# ==============================================================================
# OPTIONAL — sensible defaults, enable as needed
# ==============================================================================

AUTH_ENABLED=true
SECURE_COOKIES=true
API_KEY=
MEILI_ENV=production

# AI/VLM (enables document extraction + RAG)
GEMINI_API_KEY=
EXTRACTION_MODEL=gemini-3.1-flash-preview
RAG_MODEL=gemini-2.5-flash

# Storage (mounted via docker-compose.override.yml)
UPLOAD_DIR=/app/uploads
SCANS_DIR=/app/shenlab-docs
DEVICES_DIR=/app/shenlab-devices

# ==============================================================================
# CLOUDFLARE TUNNEL — for internet-accessible deployment
# ==============================================================================

# Get token: cloudflared tunnel token shenlab-prod
# Start with: docker compose --profile tunnel up -d
CLOUDFLARED_TOKEN=

# ==============================================================================
# OPERATIONAL NOTES
# ==============================================================================
#
# Credential rotation (every 90 days):
#   POSTGRES_PASSWORD, POSTGRES_RO_PASSWORD, ADMIN_SECRET_KEY, MEILI_MASTER_KEY
#
# Backups:
#   Daily PostgreSQL dumps at 2 AM (configure via cron)
#   7-day retention, optional offsite sync to S3/GCS
#
# First deployment:
#   docker compose up -d
#   docker compose exec app uv run alembic upgrade head
#   docker compose exec app uv run python scripts/populate_db.py
#
# Subsequent deployments:
#   git pull && docker compose up -d --build
