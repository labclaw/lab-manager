# LabClaw Lab Manager — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# --- Required ---
DATABASE_URL=postgresql+psycopg://labmanager:labmanager@localhost:5432/labmanager
MEILISEARCH_URL=http://localhost:7700
ADMIN_SECRET_KEY=           # Required: python -c "import secrets; print(secrets.token_hex(32))"

# --- Authentication ---
AUTH_ENABLED=true            # Set false for local dev without login
API_KEY=                     # Optional: for programmatic API access (X-Api-Key header)
SECURE_COOKIES=false         # Set true when behind HTTPS reverse proxy

# --- Database ---
DATABASE_READONLY_URL=       # Optional: postgresql+psycopg://labmanager_ro:...  (RAG queries)

# --- Search ---
MEILISEARCH_API_KEY=         # Optional: required if Meilisearch has auth enabled

# --- AI/VLM ---
GEMINI_API_KEY=              # For Gemini-based extraction and RAG
EXTRACTION_API_KEY=          # Alias for GEMINI_API_KEY (used by extraction pipeline)
MISTRAL_API_KEY=             # For Mistral Pixtral OCR provider
EXTRACTION_MODEL=gemini-3.1-flash-preview
OCR_MODEL=Qwen/Qwen3-VL-4B-Instruct
RAG_MODEL=gemini-2.5-flash

# --- Storage ---
UPLOAD_DIR=uploads           # Relative or absolute path for uploaded documents
