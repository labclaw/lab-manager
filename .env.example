# LabClaw Lab Manager — Environment Variables
# Copy to .env and edit passwords. Never commit .env to git.
#
# Quick start:  cp .env.example .env && docker compose up -d

# --- Docker Compose Required ---
POSTGRES_PASSWORD=changeme           # CHANGE THIS
POSTGRES_RO_PASSWORD=changeme_ro     # CHANGE THIS
MEILI_MASTER_KEY=changeme_meili      # CHANGE THIS
ADMIN_SECRET_KEY=changeme_secret     # CHANGE THIS — session signing key
ADMIN_PASSWORD=changeme_admin        # CHANGE THIS — SQLAdmin panel password

# --- Lab Identity ---
LAB_NAME=My Lab                 # Displayed in sidebar and PWA
# Optional: e.g., "MIT Neuroscience"
LAB_SUBTITLE=

# --- Authentication ---
AUTH_ENABLED=true            # Set false for local dev without login
# Optional: programmatic API access (X-Api-Key header)
API_KEY=
SECURE_COOKIES=true          # Set true behind HTTPS (default: true for security)

# --- Local Dev Only (ignored by Docker Compose) ---
DATABASE_URL=postgresql+psycopg://labmanager:labmanager@localhost:5432/labmanager
MEILISEARCH_URL=http://localhost:7700
# Optional: read-only DB for RAG queries
DATABASE_READONLY_URL=
# Optional: if Meilisearch has auth
MEILISEARCH_API_KEY=

# --- AI/VLM ---
# For extraction and RAG
GEMINI_API_KEY=

# OCR tier: "auto" (local first, API fallback), "local" (vLLM only), "api" (cloud only)
OCR_TIER=auto
OCR_MODEL=gemini-2.5-flash
# Local OCR model (provider name): deepseek_ocr, paddleocr_vl, qwen3_vl, glm_4v
OCR_LOCAL_MODEL=deepseek_ocr
# vLLM endpoint for local OCR models
OCR_LOCAL_URL=http://localhost:8000/v1
# Mistral API key (for Mistral OCR 3 and Pixtral)
MISTRAL_API_KEY=

EXTRACTION_MODEL=gemini-2.5-flash
RAG_MODEL=gemini-2.5-flash   # LiteLLM model. Unprefixed values default to Gemini. Examples: gemini-2.5-flash, openai/gpt-4.1, nvidia_nim/meta/llama-3.1-70b-instruct
# Optional: OpenAI-compatible / LiteLLM backend key
RAG_API_KEY=
# Optional: OpenAI-compatible / LiteLLM base URL
RAG_BASE_URL=
# Optional: NVIDIA Build / NIM key. Defaults RAG_BASE_URL to https://integrate.api.nvidia.com/v1
NVIDIA_BUILD_API_KEY=

# --- Storage ---
UPLOAD_DIR=uploads           # Relative or absolute path for uploaded documents
# Optional: path to scanned document images (served at /scans)
SCANS_DIR=
# Optional: path to device photos (served at /lab-devices)
DEVICES_DIR=

# --- Cloudflare Tunnel (Production) ---
DOMAIN=localhost             # e.g., shenlab.labclaw.org
# Cloudflare Tunnel connector token
CLOUDFLARED_TOKEN=
